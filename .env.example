# ===========================================
# SiteCheck Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_URL=postgresql://postgres.your-project:your-password@aws-0-us-west-2.pooler.supabase.com:5432/postgres

# AI (Claude)
ANTHROPIC_API_KEY=sk-ant-api03-your-key

# Maps
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-token

# Weather
OPENWEATHERMAP_API_KEY=your-openweathermap-key

# Admin
ADMIN_MIGRATION_TOKEN=generate-a-random-64-char-hex-string
